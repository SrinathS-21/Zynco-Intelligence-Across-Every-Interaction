generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  agents       Agent[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Agent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("GMAIL_CLASSIFIER")
  status      String   @default("ACTIVE")
  config      Json     @default("{}")
  data        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activatedAt DateTime?

  @@index([userId, type])
}

model ScheduledMessage {
  id           String    @id @default(cuid())
  userId       String
  platform     String    @default("whatsapp")
  to           String
  content      String
  scheduledFor DateTime
  status       String    @default("PENDING") // PENDING, SENT, FAILED
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, status, scheduledFor])
}

model UnifiedMessage {
  id           String    @id @default(cuid())
  userId       String
  platform     String    @default("whatsapp")
  contactId    String    // e.g. number@c.us
  contactName  String?
  content      String
  direction    String    @default("INBOUND") // INBOUND or OUTBOUND
  timestamp    DateTime  @default(now())
  metadata     Json?     @default("{}")

  @@index([userId, platform, contactId, timestamp])
}
